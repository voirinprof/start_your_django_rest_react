# Django
DJANGO_SECRET_KEY=change-moi-en-production-avec-une-cle-aleatoire-longue
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Base de données (doit correspondre au docker-compose.yml)
POSTGRES_DB=geodb
POSTGRES_USER=geouser
POSTGRES_PASSWORD=geopassword
POSTGRES_HOST=db
POSTGRES_PORT=5432

# CORS - origine autorisée pour le frontend React
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
